# Five-seed overhead matrix config for Phase 13.9.
#
# This config keeps the same tiny workload as Phase 13.8 but expands the seed
# set from 3 to 5 so TPOT/TTFT and scheduler-overhead differences can be checked
# more rigorously without broadening the benchmark campaign.

MODEL="Qwen/Qwen3-0.6B"
SERVED_MODEL_NAME="qwen3-0.6b"
TOKENIZER="Qwen/Qwen3-0.6B"

HOST="127.0.0.1"
PORT="8000"

MAX_MODEL_LEN="2048"
MAX_NUM_BATCHED_TOKENS="2048"
MAX_NUM_SEQS="64"
GPU_MEMORY_UTILIZATION="0.80"

NUM_PROMPTS="4"
RANDOM_INPUT_LEN="32"
RANDOM_OUTPUT_LEN="16"
MAX_CONCURRENCY="2"
REQUEST_RATE="inf"

MATRIX_SCHEDULERS="simple_policy_1 primal_lp_dry_run"
MATRIX_SEEDS="0 1 2 3 4"
MATRIX_WORKLOAD_LABEL_PREFIX="tiny5"