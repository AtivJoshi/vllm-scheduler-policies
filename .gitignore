# Python bytecode/cache
__pycache__/
*.py[cod]
*$py.class

# Editable/build metadata
*.egg-info/
build/
dist/

# Test/cache artifacts
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Local logs/results
*.log

# Claude Transcripts
claude_transcript/*

# Experiment raw artifacts
experiments/**/runs/*
!experiments/**/runs/.gitkeep
experiments/**/tmp/*
!experiments/**/tmp/.gitkeep

# Experiment logs and transient outputs
experiments/**/*.jsonl
experiments/**/*.pid
experiments/**/server_stdout*
experiments/**/server_stderr*
experiments/**/bench_stdout*
experiments/**/bench_stderr*
experiments/**/health.txt
experiments/**/single_chat_response.json
experiments/**/manifest.local.json